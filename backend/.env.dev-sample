# The common approach is to use dockerized Postgres
# In such a case take settings from it's environment
POSTGRES_HOST=localhost
POSTGRES_PORT=5432  #TODO: get from docker's .env (the port specified in POSTGRES_EXPOSE variable)
POSTGRES_USER=mydic #TODO: get from docker's .env
POSTGRES_PASSWORD=  #TODO: get from docker's .env
POSTGRES_DB=mydic   #TODO: get from docker's .env

# Authentication
JWT_SECRET_KEY= #TODO: generate with: openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=10080 # 7 days

REGISTRATION_ENABLED=true

# Supported languages (comma-separated ISO 639-1 codes)
SUPPORTED_LANGS=en,es,pt,fr,ru,de,it,zh,ja

# Libre Translate
LIBRE_TRANSLATE_ENABLED=true
LIBRE_TRANSLATE_URL=http://localhost:5000

# Yandex Cloud Translation API
YANDEX_TRANSLATE_ENABLED=true
YANDEX_TRANSLATE_API_KEY=

# Reverso Context (lexical + context examples)
REVERSO_ENABLED=true

# Free Dictionary API (English definitions)
FREEDICT_ENABLED=true

# Wiktionary REST API (definitions + context examples)
WIKITIONARY_ENABLED=true

# Tatoeba sentence corpus (context examples)
TATOEBA_ENABLED=true

# Piper TTS
PIPER_ENABLED=true
PIPER_VOICES_DIR=../tts/piper/voices
PIPER_SLOW_RATIO=0.5

# Kokoro TTS
KOKORO_ENABLED=true
KOKORO_URL=http://localhost:8880
#KOKORO_SLOW_RATIO=

# TTS common
TTS_CACHE_DIR=../tts/cache
TTS_SLOW_RATIO=0.75

# How long to wait before retrying a failed API call
API_FAILURE_RETRY_SECONDS=600 # 10 minutes

# CORS (space-separated origins for dev overrides)
# CORS_ORIGINS=http://localhost:5173 http://localhost:3000
