services:
  db:
    extends:
      file: core.yaml
      service: db
    ports:
      - "${POSTGRES_EXPOSE}:5432"

  libretranslate:
    extends:
      file: providers.yaml
      service: libretranslate
    ports:
      - "${LT_EXPOSE}:5000"

  kokoro:
    extends:
      file: providers.yaml
      service: kokoro
    ports:
      - "${KOKORO_EXPOSE}:8880"

volumes:
  mydic-db:
  libretranslate:
  kokoro-models:
  kokoro-cache:

networks:
  mydic:
    name: mydic
    driver: bridge
    driver_opts:
      com.docker.network.bridge.name: mydic
